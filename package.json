{
  "name": "controller1",
  "version": "0.3.2",
  "description": "Persistent controller calibration and remapping for SteamOS",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "python3 -m unittest discover -s tests -v"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/0x00by73/Controller1.git"
  },
  "keywords": ["decky", "steam-deck", "controller", "remapping", "uinput"],
  "author": "Martin",
  "license": "MIT",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": ["react", "react-dom"]
    }
  }
}
